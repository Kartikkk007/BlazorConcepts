@page "/form"
@using MyFirstBlazorApp.Models
@rendermode InteractiveServer

<h3>UserForm</h3>

<EditForm Model="@user" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator/>
    <ValidationSummary/>
    <div>
        <label>FullName:</label>
        <InputText @bind-Value="user.FullName"/>
        <ValidationMessage For="@(() => user.FullName)"/>
    </div>

    <div>
        <label>Email:</label>
        <InputText @bind-Value="user.Email" />
        <ValidationMessage For="@(() => user.Email)"/>  
    </div>
    
    <div>
        <label>Age:</label>
        <InputNumber @bind-Value="user.Age" />
        <ValidationMessage For="@(() => user.Age)" />

    </div>

    <div>
        <label>Password:</label>
        <InputText @bind-Value="user.Password" type="password" />
        <ValidationMessage For="@(() => user.Password)" />
    </div>

    <div>
        <label> Confirm Password:</label>
        <InputText @bind-Value="user.ConfirmPassword" type="password" />
        <ValidationMessage For="@(() => user.ConfirmPassword)" />
    </div>

    <div>
        <label> Phone Number:</label>
        <InputText @bind-Value="user.PhoneNumber" />
        <ValidationMessage For="@(() => user.PhoneNumber)" />
    </div>

     <div>
        <label> URL:</label>
        <InputText @bind-Value="user.URL" />
        <ValidationMessage For="@(() => user.URL)" />
    </div>

    <div>
        <label> Credit Card Number:</label>
        <InputText @bind-Value="user.CreditCardNumber" />
        <ValidationMessage For="@(() => user.CreditCardNumber)" />
    </div>


    <br />
    
    <button class="btn btn-primary" type="submit">Submit</button>
   </EditForm>
   
   <hr />
  
@if (isSubmitted == true)
{
    <h2>Submitted Data</h2>
    <p><b>FullName: </b> @user.FullName</p>
    <p><b>Email: </b> @user.Email</p>
    <p><b>Age: </b> @user.Age</p>
}


@code {

    UserProfile user = new UserProfile();
    bool isSubmitted = false;

    void HandleSubmit()
    {
        isSubmitted = true;
    }
} 
